# =====================================================================
# SYSTEM-TEST ENV  ·  Apple M5 Max (48 GB) — the capable box
# =====================================================================
# Committed on purpose (NOT gitignored) so it travels via GitHub. On the M5 Max:
#     git fetch && git checkout systest/frontier-external-v0.2.0
#     cp .env-system-test .env
#     ./.venv/bin/python -m harness.run --manifest tasks/frontier_external_manifest.json --backend monolithic --trials 5
# Purpose: calibrate the new externally-sourced frontier tier (MATH-500 / MBPP /
# MuSiQue) against a CAPABLE model — the set overshot the 0.4-0.7 band on the 4B
# dev model (gemma-4-e4b) and is aimed at this 14B-class target.

# --- backend: the capable pinned model (v1 baseline; already on the M5 Max) ---
LLM_PROVIDER=openai
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=deepseek-r1-distill-qwen-14b
LLM_API_KEY=lm-studio

# MODEL_TAG / MODEL_QUANT intentionally UNSET: running the ACTUAL pinned model,
# so rows/reports should carry the frozen canonical tag from config.yaml
# (deepseek-r1-14b-distill-q4_k_m / Q4_K_M). Only set these if you swap in a
# DIFFERENT capable model for the system test, e.g.:
#   LLM_MODEL=qwen/qwen3.6-35b-a3b
#   MODEL_TAG=qwen3.6-35b-a3b
#   MODEL_QUANT=Q4_K_M

# --- judge: different family from the Qwen-based backend (no self-preference) ---
# llama-3.2-3b is fast/reliable for the verdict; on 48 GB you can swap up to a
# larger different-family judge (e.g. a Gemma that loads reliably) for better
# quality scoring — see docs/STRETCH_GOALS.md.
JUDGE_PROVIDER=openai
JUDGE_BASE_URL=http://localhost:1234/v1
JUDGE_MODEL=llama-3.2-3b-instruct
JUDGE_API_KEY=lm-studio
