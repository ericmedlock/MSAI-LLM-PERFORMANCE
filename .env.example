# Per-machine LLM serving overrides. Copy to `.env` (which is gitignored) and
# edit for your box. These override the ACTIVE environment's provider/base_url/
# model/api_key from config/config.yaml WITHOUT editing that committed file.
# Only endpoint/provider/model/key (and the dev-only model *label*) are
# overridable here — pinned scientific parameters (temperature, N, topologies,
# ...) live in config.yaml only.

# provider: openai (LM Studio / vLLM / llama.cpp) | ollama
LLM_PROVIDER=openai

# LM Studio default (note the trailing /v1). Ollama would be http://localhost:11434
LLM_BASE_URL=http://localhost:1234/v1

# Provider-specific model id.
#   LM Studio (this machine): deepseek-r1-distill-qwen-14b
#   Ollama:                   deepseek-r1:14b
LLM_MODEL=deepseek-r1-distill-qwen-14b

# Canonical model identity stamped on every row + shown in reports. Normally the
# PINNED value from config.yaml — leave UNSET for pre-registered runs. On a dev
# box serving a different model than the frozen one, set these so rows/reports
# are labeled with what actually ran (otherwise they show the frozen tag).
# MODEL_TAG=gemma-4-e4b
# MODEL_QUANT=Q4

# API key. LM Studio ignores the value but the header may be required; any
# non-empty string works. Real OpenAI/hosted endpoints need a genuine key.
LLM_API_KEY=lm-studio

# --- LLM-as-judge (post-processing pass) overrides ---
# Judge model should be a DIFFERENT family from the backend to avoid self-
# preference. Backend is Qwen-based; default judge is Gemma.
JUDGE_PROVIDER=openai
JUDGE_BASE_URL=http://localhost:1234/v1
JUDGE_MODEL=llama-3.2-3b-instruct
JUDGE_API_KEY=lm-studio
